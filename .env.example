# Copy to .env and fill in the values you need.
#   cp .env.example .env

# ---- Service ----
SERVICE_NAME=notifty
ENV=dev
DEBUG=1

# Deep link scheme used in notification payloads (e.g. notifty://billing)
DEEPLINK_SCHEME=notifty

# ---- Redis (streams, locks, counters) ----
REDIS_URL=redis://localhost:6379/0
REDIS_RAW_STREAM=notif_events_raw
REDIS_ENRICHED_STREAM=notif_events_enriched
REDIS_DELIVERY_STREAM=notif_delivery_tasks
REDIS_DLQ_STREAM=notif_events_dlq
REDIS_STREAM_MAX_LENGTH=100000
REDIS_STREAM_TTL_SECONDS=172800

# ---- PostgreSQL ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=notification_db
DB_USER=postgres
DB_PASSWORD=postgres

# ---- Firebase Cloud Messaging ----
# The FULL service-account JSON as a single-line string. Required only for the
# delivery worker to actually send pushes; the rest of the pipeline runs without it.
FIREBASE_SERVICE_ACCOUNT_JSON=
